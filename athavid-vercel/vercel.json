{
  "buildCommand": "echo 'Using pre-built dist'",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"},
        {"key": "Pragma", "value": "no-cache"},
        {"key": "Expires", "value": "0"}
      ]
    },
    {
      "source": "/",
      "headers": [
        {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
