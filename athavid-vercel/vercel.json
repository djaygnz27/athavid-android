{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/proxy.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/proxy/:path*", "destination": "/api/proxy" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
